{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fazi",
  "version": "0.1.0",
  "identifier": "com.pascalroger.fazi",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Fazi",
        "width": 1180,
        "height": 760,
        "minWidth": 640,
        "minHeight": 400,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "img-src": "'self' data: icon: thumb: preview: http://icon.localhost http://thumb.localhost http://preview.localhost",
        "media-src": "'self' preview: http://preview.localhost",
        "style-src": "'self' 'unsafe-inline'",
        "font-src": "'self' data:",
        "connect-src": "'self' ipc: http://ipc.localhost preview: http://preview.localhost",
        "worker-src": "'self' blob:",
        "object-src": "'none'",
        "frame-src": "'none'"
      },
      "assetProtocol": {
        "enable": false,
        "scope": []
      }
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "public.app-category.utilities",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "14.0"
    }
  }
}
